{
  "name": "apex-files",
  "private": true,
  "version": "0.1.0",
  "description": "Apex Files desktop app for tuner file matching and delivery, powered by Revtech.",
  "author": "Apex Files",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:backend": "python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8787 --app-dir backend",
    "dev:desktop": "npm-run-all -p dev electron:dev",
    "electron:dev": "wait-on http://localhost:5173 && cmd /C \"set ELECTRON_RUN_AS_NODE=&& set VITE_DEV_SERVER_URL=http://localhost:5173&& electron .\"",
    "build": "tsc -b && vite build",
    "build:desktop:win": "npm run build && electron-builder --win nsis --config.win.signExecutable=false",
    "build:desktop:dir": "npm run build && electron-builder --win dir --config.win.signExecutable=false",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "electron": "^40.2.1",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.apexfiles.desktop",
    "productName": "Apex Files",
    "files": [
      "app-dist/**",
      "electron/**",
      "package.json",
      "!dist{,/**/*}",
      "!**/*.map"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "allowElevation": true,
      "runAfterFinish": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Apex Files",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "artifactName": "Apex Files Setup ${version}.${ext}"
    },
    "extraMetadata": {
      "main": "electron/main.cjs"
    }
  }
}
